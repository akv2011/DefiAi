# ─────────────────────────────────────────────────────────────
# Required for portfolio deploy — must be set before deploying
# ─────────────────────────────────────────────────────────────

# Supabase (public + server-side)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_KEY=

# App base URL (used for Stripe redirect URLs and general links)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# AI provider — single key routes all LLM calls via OpenRouter
OPENROUTER_API_KEY=

# Legacy per-provider keys (no longer used; kept for reference)
# XAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# News feed
CRYPTOPANIC_API_KEY=

# ─────────────────────────────────────────────────────────────
# Optional — leave empty (or omit entirely) for portfolio deploy
# The app degrades gracefully when these are absent.
# ─────────────────────────────────────────────────────────────

# Custom MCP server — skipped when empty; chat still works without it
MATRIX_MCP_URL=
MATRIX_MCP_API_KEY=

# Stripe — all Stripe API routes return HTTP 503 when these are empty
# Set STRIPE_SECRET_KEY=sk_test_dummy to make the build-time check happy
# without enabling real Stripe functionality.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_ANNUAL_PRICE_ID=
